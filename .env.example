# Telegram
TELEGRAM_TOKEN=123456:your-bot-token-from-botfather

# Owner: telegram id that owns self-deposits + the /grant command
OWNER_ID=

# Storage (sqlite by default; point at Postgres/Supabase later)
FELT_DB=felt.db

# Blackjack table
LOBBY_SECONDS=10
TURN_SECONDS=25
SETTLE_SECONDS=4
BJ_DECKS=6
BJ_HIT_SOFT_17=0
CHIPS=5,10,25

# Gmail deposit watcher (optional; poll runs only if credentials.json exists)
GMAIL_CREDENTIALS=credentials.json
GMAIL_TOKEN=token.json
GMAIL_POLL_SECONDS=45
